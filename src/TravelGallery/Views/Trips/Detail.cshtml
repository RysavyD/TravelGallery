@model TravelGallery.Models.Trip
@{
    ViewData["Title"] = Model.Title;
    var images = Model.Media.Where(m => m.MediaType == TravelGallery.Models.MediaType.Image).ToList();
    var allMedia = Model.Media.OrderBy(m => m.SortOrder).ToList();
    var geoPhotos = allMedia.Where(m => m.Latitude.HasValue && m.Longitude.HasValue).ToList();
    var showPhotoMap = geoPhotos.Count >= 10;
}

@section Styles {
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <style>
        .pswp { --pswp-bg: #000; }
        .gallery-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 12px; }
        .gallery-cell { display: flex; flex-direction: column; }
        .gallery-item { position: relative; aspect-ratio: 4/3; overflow: hidden; cursor: pointer; border-radius: 4px; }
        .gallery-caption { font-size: .8rem; color: #6c757d; padding: 4px 2px 0; line-height: 1.3; }
        .gallery-item img, .gallery-item video { width: 100%; height: 100%; object-fit: cover; transition: transform .2s; }
        .gallery-item:hover img, .gallery-item:hover video { transform: scale(1.04); }
        .gallery-item .play-icon { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; font-size: 2.5rem; color: rgba(255,255,255,.85); pointer-events: none; }
        .pswp__custom-caption { position: absolute; left: 0; right: 0; bottom: 0; padding: 10px 20px 16px; background: linear-gradient(transparent, rgba(0,0,0,.65)); color: #fff; font-size: .9rem; text-align: center; pointer-events: none; }
        #trip-map { height: 350px; border-radius: 8px; }

        @@media print {
            nav.navbar, nav[aria-label="breadcrumb"], .no-print { display: none !important; }
            .col-lg-9 { max-width: 100% !important; width: 100% !important; flex: none !important; }
            .row { margin: 0 !important; }
            .badge { border: 1px solid #999 !important; color: #000 !important; }
            #trip-map { display: none !important; }
            .gallery-grid { grid-template-columns: repeat(3, 1fr) !important; gap: 6px !important; }
            .gallery-cell { page-break-inside: avoid; break-inside: avoid; }
            .gallery-item { cursor: default !important; }
            .gallery-item img { transition: none !important; }
            .gallery-caption { color: #333 !important; font-size: 8pt !important; }
            .trip-description { font-size: 11pt; line-height: 1.6; }
            @@page { margin: 1.5cm; }
        }
    </style>
}

<div class="row">
    <div class="col-lg-9 mx-auto">
        <nav aria-label="breadcrumb" class="mb-3">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-controller="Trips" asp-action="Index">Výlety</a></li>
                <li class="breadcrumb-item active">@Model.Title</li>
            </ol>
        </nav>

        <div class="d-flex align-items-start justify-content-between gap-2 mb-1">
            <h1 class="mb-0">@Model.Title</h1>
            <div class="d-flex gap-2 no-print flex-shrink-0 mt-1">
                @if (User.IsInRole("Admin"))
                {
                    <a asp-area="Admin" asp-controller="Trips" asp-action="Edit" asp-route-id="@Model.Id"
                       class="btn btn-outline-warning btn-sm">
                        ✏ Editovat
                    </a>
                }
                <button onclick="window.print()" class="btn btn-outline-secondary btn-sm" title="Tisk / Uložit jako PDF přes prohlížeč">
                    🖨 Vytisknout
                </button>
                <a asp-action="ExportPdf" asp-route-id="@Model.Id"
                   class="btn btn-outline-secondary btn-sm" title="Stáhnout PDF vygenerované na serveru">
                    ⬇ Stáhnout
                </a>
            </div>
        </div>
        <p class="text-muted mb-2">@Model.Date.ToString("d. MMMM yyyy", new System.Globalization.CultureInfo("cs-CZ"))</p>

        @if (Model.Tags.Any())
        {
            <div class="d-flex flex-wrap gap-1 mb-4">
                @foreach (var tag in Model.Tags.OrderBy(t => t.Name))
                {
                    <a asp-controller="Trips" asp-action="Index" asp-route-tag="@tag.Slug"
                       class="badge bg-light text-dark border text-decoration-none">@tag.Name</a>
                }
            </div>
        }
        else
        {
            <div class="mb-4"></div>
        }

        @if (!string.IsNullOrEmpty(Model.Description))
        {
            <div class="trip-description mb-5 lh-lg">
                @Html.Raw(Model.Description)
            </div>
        }

        @if (Model.Latitude.HasValue && Model.Longitude.HasValue)
        {
            <div class="mb-5">
                <h2 class="h5 mb-2">Poloha</h2>
                <div id="trip-map"></div>
                <p class="d-none d-print-block text-muted small mt-1">
                    📍 @Model.Latitude.Value.ToString("F5", System.Globalization.CultureInfo.InvariantCulture),
                    @Model.Longitude.Value.ToString("F5", System.Globalization.CultureInfo.InvariantCulture)
                </p>
            </div>
        }

        @if (showPhotoMap)
        {
            <div class="mb-5">
                <h2 class="h5 mb-2">Mapa fotek (@geoPhotos.Count)</h2>
                <div id="photo-map" style="height:400px;border-radius:8px;"></div>
            </div>
        }

        @if (allMedia.Any())
        {
            <h2 class="h5 mb-3">Fotografie (@allMedia.Count)</h2>

            <div class="gallery-grid" id="gallery">
                @for (int i = 0; i < allMedia.Count; i++)
                {
                    var m = allMedia[i];
                    <div class="gallery-cell">
                        <div class="gallery-item" id="media-@m.Id"
                             data-index="@i"
                             data-type="@(m.MediaType == TravelGallery.Models.MediaType.Video ? "video" : "image")"
                             data-src="/uploads/@Model.Id/@m.FileName"
                             @if (m.MediaType == TravelGallery.Models.MediaType.Image)
                             {
                                 <text>data-thumb="/uploads/@Model.Id/thumbs/@m.FileName"</text>
                             }>

                            @if (m.MediaType == TravelGallery.Models.MediaType.Image)
                            {
                                <img src="/uploads/@Model.Id/thumbs/@m.FileName" alt="@m.Caption" loading="lazy" />
                            }
                            else
                            {
                                <video src="/uploads/@Model.Id/@m.FileName" muted preload="none"
                                       poster="" style="background:#111"></video>
                                <div class="play-icon">&#9654;</div>
                            }
                        </div>
                        @if (!string.IsNullOrEmpty(m.Caption))
                        {
                            <div class="gallery-caption">@m.Caption</div>
                        }
                        @{
                            var exifParts = new List<string>();
                            if (m.DateTaken.HasValue) exifParts.Add("📅 " + m.DateTaken.Value.ToString("d.M.yyyy H:mm"));
                            if (!string.IsNullOrEmpty(m.CameraModel)) exifParts.Add("📷 " + m.CameraModel);
                            if (m.Latitude.HasValue) exifParts.Add("📍");
                        }
                        @if (exifParts.Any())
                        {
                            <div class="gallery-caption" style="font-size:.7rem;opacity:.7;">@string.Join(" · ", exifParts)</div>
                        }
                    </div>
                }
            </div>
        }
        else
        {
            <p class="text-muted">Tento výlet nemá žádná média.</p>
        }
    </div>
</div>

@section Scripts {
    @if (Model.Latitude.HasValue && Model.Longitude.HasValue || showPhotoMap)
    {
        <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    }
    @if (Model.Latitude.HasValue && Model.Longitude.HasValue)
    {
        <script>
            const map = L.map('trip-map').setView([@Model.Latitude.Value.ToString("G", System.Globalization.CultureInfo.InvariantCulture), @Model.Longitude.Value.ToString("G", System.Globalization.CultureInfo.InvariantCulture)], 10);
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>'
            }).addTo(map);
            L.marker([@Model.Latitude.Value.ToString("G", System.Globalization.CultureInfo.InvariantCulture), @Model.Longitude.Value.ToString("G", System.Globalization.CultureInfo.InvariantCulture)])
                .addTo(map)
                .bindPopup('@Html.Raw(Html.Encode(Model.Title))')
                .openPopup();
        </script>
    }
    @if (showPhotoMap)
    {
        <script>
            (function() {
                const photos = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                    geoPhotos.Select(p => new {
                        lat = p.Latitude!.Value,
                        lng = p.Longitude!.Value,
                        thumb = $"/uploads/{Model.Id}/thumbs/{p.FileName}",
                        caption = p.Caption,
                        id = p.Id
                    }),
                    new System.Text.Json.JsonSerializerOptions {
                        Encoder = System.Text.Encodings.Web.JavaScriptEncoder.Default
                    }
                ));
                const map = L.map('photo-map');
                L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                    attribution: '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>'
                }).addTo(map);
                const bounds = [];
                photos.forEach(p => {
                    const popup = `<div style="text-align:center;">
                        <img src="${p.thumb}" style="max-width:120px;border-radius:4px;" /><br/>
                        <small>${p.caption || ''}</small></div>`;
                    L.marker([p.lat, p.lng]).addTo(map).bindPopup(popup);
                    bounds.push([p.lat, p.lng]);
                });
                map.fitBounds(bounds, { padding: [30, 30], maxZoom: 14 });
            })();
        </script>
    }
    <script type="module">
        import PhotoSwipeLightbox from 'https://cdn.jsdelivr.net/npm/photoswipe@5/dist/photoswipe-lightbox.esm.js';
        import PhotoSwipe from 'https://cdn.jsdelivr.net/npm/photoswipe@5/dist/photoswipe.esm.js';

        const items = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
            allMedia.Select(m => {
                var exifLine = new List<string>();
                if (m.DateTaken.HasValue) exifLine.Add("📅 " + m.DateTaken.Value.ToString("d.M.yyyy H:mm"));
                if (!string.IsNullOrEmpty(m.CameraModel)) exifLine.Add("📷 " + m.CameraModel);
                if (!string.IsNullOrEmpty(m.ExifSummary)) exifLine.Add(m.ExifSummary);
                var fullCaption = m.Caption ?? "";
                if (exifLine.Any()) fullCaption += (string.IsNullOrEmpty(fullCaption) ? "" : "<br/>") +
                    "<span style='font-size:.75rem;opacity:.7;'>" + string.Join(" · ", exifLine) + "</span>";
                return new {
                    src = $"/uploads/{Model.Id}/{m.FileName}",
                    thumb = m.MediaType == TravelGallery.Models.MediaType.Image ? $"/uploads/{Model.Id}/thumbs/{m.FileName}" : (string?)null,
                    type = m.MediaType == TravelGallery.Models.MediaType.Video ? "video" : "image",
                    caption = fullCaption,
                    w = 1920,
                    h = 1080
                };
            }),
            new System.Text.Json.JsonSerializerOptions
            {
                // JavaScriptEncoder.Default encodes HTML-sensitive characters (<, >, &, ', ")
                // as unicode escape sequences, preventing XSS injection via caption or filenames.
                Encoder = System.Text.Encodings.Web.JavaScriptEncoder.Default
            }));

        const gallery = document.getElementById('gallery');
        const galleryItems = gallery.querySelectorAll('.gallery-item');

        galleryItems.forEach((el) => {
            el.addEventListener('click', () => {
                const idx = parseInt(el.dataset.index);
                const item = items[idx];

                if (item.type === 'video') {
                    const captionHtml = item.caption
                        ? `<p style="color:#fff;font-size:.9rem;margin:10px 0 0;text-align:center;max-width:90vw;padding:0 16px;">${item.caption}</p>`
                        : '';
                    const pswp = new PhotoSwipe({
                        dataSource: [{
                            html: `<div style="display:flex;flex-direction:column;align-items:center;justify-content:center;height:100%;">
                                     <video controls autoplay style="max-width:95vw;max-height:${item.caption ? '82vh' : '90vh'};"
                                            src="${item.src}"></video>
                                     ${captionHtml}
                                   </div>`
                        }],
                        index: 0
                    });
                    pswp.init();
                } else {
                    const imageIdx = items.slice(0, idx + 1).filter(i => i.type === 'image').length - 1;

                    const lightbox2 = new PhotoSwipeLightbox({
                        dataSource: items
                            .filter(i => i.type === 'image')
                            .map(i => ({ src: i.src, width: 1920, height: 1080, alt: i.caption })),
                        pswpModule: PhotoSwipe
                    });

                    lightbox2.on('uiRegister', function () {
                        lightbox2.pswp.ui.registerElement({
                            name: 'custom-caption',
                            className: 'pswp__custom-caption',
                            order: 9,
                            isButton: false,
                            appendTo: 'root',
                            onInit: (el, pswp) => {
                                pswp.on('change', () => {
                                    const caption = pswp.currSlide.data.alt;
                                    el.innerHTML = caption || '';
                                    el.hidden = !caption;
                                });
                            }
                        });
                    });

                    lightbox2.init();
                    lightbox2.loadAndOpen(Math.max(0, imageIdx));
                }
            });
        });
    </script>
}
