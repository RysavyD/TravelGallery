@model TravelGallery.Areas.Admin.ViewModels.TripFormViewModel
@{
    ViewData["Title"] = "Nový výlet";
}

<h1 class="h3 mb-4">Nový výlet</h1>

<div class="row">
    <div class="col-lg-8">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Title" class="form-label">Název výletu</label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Date" class="form-label">Datum</label>
                <input asp-for="Date" type="date" class="form-control"
                       value="@Model.Date.ToString("yyyy-MM-dd")" />
                <span asp-validation-for="Date" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label">Popis výletu</label>
                <div id="quill-editor" style="min-height:250px;"></div>
                <input type="hidden" asp-for="Description" id="Description" />
            </div>

            <div class="mb-4">
                <label asp-for="TagNames" class="form-label">Tagy</label>
                <div id="tag-chips" class="d-flex flex-wrap gap-1 mb-1"></div>
                <div class="input-group">
                    <input type="text" id="tag-input" class="form-control"
                           placeholder="Zadej tag a stiskni Enter nebo čárku…" autocomplete="off" />
                    <button type="button" class="btn btn-outline-secondary" id="tag-add-btn">Přidat</button>
                </div>
                <input type="hidden" asp-for="TagNames" id="TagNames" />
                <div class="form-text">Tagy slouží k filtrování výletů. Příklad: Hory, Zima, Slovensko</div>
            </div>

            <div class="mb-4">
                <label class="form-label">Poloha na mapě</label>
                <div class="row g-2 mb-2">
                    <div class="col-sm-6">
                        <input asp-for="Latitude" class="form-control" placeholder="Zeměpisná šířka (např. 50.0755)" id="Latitude" />
                        <span asp-validation-for="Latitude" class="text-danger small"></span>
                    </div>
                    <div class="col-sm-6">
                        <input asp-for="Longitude" class="form-control" placeholder="Zeměpisná délka (např. 14.4378)" id="Longitude" />
                        <span asp-validation-for="Longitude" class="text-danger small"></span>
                    </div>
                </div>
                <div id="map-picker" style="height:300px;border-radius:6px;border:1px solid #dee2e6;"></div>
                <div class="form-text">Klikni na mapu pro nastavení polohy, nebo zadej souřadnice ručně.</div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger">Uložit a přidat média</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Zrušit</a>
            </div>
        </form>
    </div>
</div>

@section Styles {
    <link href="https://cdn.jsdelivr.net/npm/quill@2/dist/quill.snow.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/quill@2/dist/quill.js"></script>
    <script>
        const quill = new Quill('#quill-editor', { theme: 'snow' });
        const hiddenInput = document.getElementById('Description');

        // Load existing content
        if (hiddenInput.value) {
            quill.clipboard.dangerouslyPasteHTML(hiddenInput.value);
        }

        // Sync on every change so the value is always ready before submit
        quill.on('text-change', () => {
            hiddenInput.value = quill.root.innerHTML;
        });

        // Fallback: also sync on submit
        document.querySelector('form').addEventListener('submit', () => {
            hiddenInput.value = quill.root.innerHTML;
        });
    </script>
    <script>
        // ── Tag chip input ────────────────────────────────────────────────
        const tagInput   = document.getElementById('tag-input');
        const tagHidden  = document.getElementById('TagNames');
        const tagChips   = document.getElementById('tag-chips');
        let tags = tagHidden.value ? tagHidden.value.split(',').map(t => t.trim()).filter(Boolean) : [];

        function renderChips() {
            tagChips.innerHTML = '';
            tags.forEach((t, i) => {
                const chip = document.createElement('span');
                chip.className = 'badge bg-secondary d-flex align-items-center gap-1';
                chip.style.fontSize = '.85rem';
                chip.innerHTML = `${t} <button type="button" class="btn-close btn-close-white" style="font-size:.6rem;" aria-label="Odebrat"></button>`;
                chip.querySelector('button').addEventListener('click', () => { tags.splice(i, 1); renderChips(); });
                tagChips.appendChild(chip);
            });
            tagHidden.value = tags.join(', ');
        }

        function addTag(val) {
            const name = val.trim().replace(/,$/, '').trim();
            if (name && !tags.some(t => t.toLowerCase() === name.toLowerCase())) {
                tags.push(name);
                renderChips();
            }
            tagInput.value = '';
        }

        tagInput.addEventListener('keydown', e => {
            if (e.key === 'Enter') { e.preventDefault(); addTag(tagInput.value); }
        });
        tagInput.addEventListener('input', e => {
            if (tagInput.value.endsWith(',')) addTag(tagInput.value);
        });
        document.getElementById('tag-add-btn').addEventListener('click', () => addTag(tagInput.value));
        renderChips();
    </script>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
        // ── Map picker ────────────────────────────────────────────────────────
        const latInput = document.getElementById('Latitude');
        const lngInput = document.getElementById('Longitude');

        const map = L.map('map-picker').setView([50.0, 15.0], 7);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>'
        }).addTo(map);

        let marker = null;

        function setMarker(lat, lng) {
            if (marker) marker.setLatLng([lat, lng]);
            else marker = L.marker([lat, lng], { draggable: true }).addTo(map);
            marker.on('dragend', () => {
                const pos = marker.getLatLng();
                latInput.value = pos.lat.toFixed(6);
                lngInput.value = pos.lng.toFixed(6);
            });
            latInput.value = lat.toFixed(6);
            lngInput.value = lng.toFixed(6);
        }

        map.on('click', e => {
            setMarker(e.latlng.lat, e.latlng.lng);
        });

        function syncMapFromInputs() {
            const lat = parseFloat(latInput.value);
            const lng = parseFloat(lngInput.value);
            if (!isNaN(lat) && !isNaN(lng)) {
                setMarker(lat, lng);
                map.setView([lat, lng], map.getZoom());
            }
        }

        latInput.addEventListener('change', syncMapFromInputs);
        lngInput.addEventListener('change', syncMapFromInputs);
    </script>
}
