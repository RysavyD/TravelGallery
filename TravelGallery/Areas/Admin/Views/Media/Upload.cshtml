@model TravelGallery.Models.Trip
@{
    ViewData["Title"] = $"Média – {Model.Title}";
}

@section Styles {
    <style>
        .media-thumb { width: 120px; height: 90px; object-fit: cover; border-radius: 4px; }
        .media-card { border: 1px solid #dee2e6; border-radius: 8px; padding: 8px; background: #fff; position: relative; }
        .drop-zone { border: 2px dashed #adb5bd; border-radius: 8px; padding: 2rem; text-align: center; cursor: pointer; transition: background .2s; }
        .drop-zone.dragover { background: #f8f9fa; border-color: #6c757d; }
        .drag-handle { position: absolute; top: 6px; left: 8px; cursor: grab; color: #adb5bd; font-size: 1rem; line-height: 1; user-select: none; }
        .drag-handle:hover { color: #6c757d; }
        .sortable-ghost { opacity: 0.4; }
        .sortable-chosen { box-shadow: 0 0 0 2px #0d6efd44; }
        .preview-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; }
        .preview-item { display: flex; flex-direction: column; }
        .preview-thumb { aspect-ratio: 4/3; overflow: hidden; border-radius: 4px; background: #e9ecef; display: flex; align-items: center; justify-content: center; }
        .preview-thumb img { width: 100%; height: 100%; object-fit: cover; }
        .preview-thumb .video-icon { font-size: 1.8rem; color: #6c757d; }
        .preview-label { font-size: .7rem; color: #6c757d; margin-top: 3px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    </style>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-0">Média</h1>
        <small class="text-muted">@Model.Title &bull; @Model.Date.ToString("d. M. yyyy")</small>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-controller="Trips" asp-route-id="@Model.Id" class="btn btn-outline-secondary btn-sm">Upravit výlet</a>
        <a asp-action="Index" asp-controller="Trips" class="btn btn-outline-secondary btn-sm">Zpět na výlety</a>
    </div>
</div>

<div class="row mb-5">
    <div class="col-lg-6">
        <form asp-action="Upload" asp-route-tripId="@Model.Id" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div class="drop-zone" id="dropZone">
                <p class="mb-2">&#128444; Přetáhněte soubory sem nebo klikněte pro výběr</p>
                <input type="file" name="files" id="fileInput" multiple accept="image/*,video/*"
                       class="d-none" />
                <button type="button" class="btn btn-outline-secondary btn-sm"
                        onclick="document.getElementById('fileInput').click()">Vybrat soubory</button>
            </div>
            <div id="previewGrid" class="preview-grid mt-3"></div>
            <div id="progressWrap" class="mt-3" style="display:none;">
                <div class="d-flex justify-content-between small mb-1">
                    <span id="progressLabel">Nahrávám…</span>
                    <span id="progressPct">0 %</span>
                </div>
                <div class="progress">
                    <div id="progressBar" class="progress-bar progress-bar-striped progress-bar-animated"
                         role="progressbar" style="width:0%"></div>
                </div>
            </div>
            <button type="button" class="btn btn-danger mt-3 w-100" id="uploadBtn" disabled>
                Nahrát vybrané soubory
            </button>
        </form>
    </div>
</div>

@if (Model.Media.Any())
{
    <div class="d-flex align-items-center gap-3 mb-3">
        <h2 class="h5 mb-0">Nahraná média (@Model.Media.Count)</h2>
        <span id="reorderToast" class="text-success small" style="display:none;">✓ Pořadí uloženo</span>
    </div>
    <div class="row row-cols-2 row-cols-md-4 row-cols-lg-5 g-3" id="mediaList">
        @foreach (var m in Model.Media.OrderBy(x => x.SortOrder))
        {
            <div class="col" data-id="@m.Id">
                <div class="media-card text-center">
                    <span class="drag-handle" title="Přetáhnout pro změnu pořadí">&#9776;</span>
                    @if (m.MediaType == TravelGallery.Models.MediaType.Image)
                    {
                        <img src="/uploads/@Model.Id/thumbs/@m.FileName" class="media-thumb mb-2" alt="@m.Caption" loading="lazy" />
                    }
                    else
                    {
                        <div class="media-thumb mb-2 d-flex align-items-center justify-content-center bg-dark text-white mx-auto">
                            &#9654; Video
                        </div>
                    }

                    <form asp-action="UpdateCaption" method="post" class="d-flex gap-1 mb-2">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@m.Id" />
                        <input type="text" name="caption" value="@m.Caption" class="form-control form-control-sm" />
                        <button type="submit" class="btn btn-sm btn-outline-secondary">&#10003;</button>
                    </form>

                    <form asp-action="Delete" method="post"
                          onsubmit="return confirm('Smazat toto médium?')">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@m.Id" />
                        <button type="submit" class="btn btn-sm btn-outline-danger w-100">Smazat</button>
                    </form>
                </div>
            </div>
        }
    </div>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.6/Sortable.min.js"></script>
    <script>
        // --- Upload drag & drop + preview ---
        const input = document.getElementById('fileInput');
        const uploadBtn = document.getElementById('uploadBtn');
        const dropZone = document.getElementById('dropZone');
        const previewGrid = document.getElementById('previewGrid');
        const progressWrap = document.getElementById('progressWrap');
        const progressBar = document.getElementById('progressBar');
        const progressPct = document.getElementById('progressPct');
        const progressLabel = document.getElementById('progressLabel');

        let selectedFiles = [];

        input.addEventListener('change', () => handleFiles(input.files));

        dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.classList.add('dragover'); });
        dropZone.addEventListener('dragleave', () => dropZone.classList.remove('dragover'));
        dropZone.addEventListener('drop', e => {
            e.preventDefault();
            dropZone.classList.remove('dragover');
            handleFiles(e.dataTransfer.files);
        });

        function handleFiles(files) {
            selectedFiles = Array.from(files);
            uploadBtn.disabled = selectedFiles.length === 0;
            renderPreviews(selectedFiles);
        }

        function renderPreviews(files) {
            previewGrid.innerHTML = '';
            files.forEach(file => {
                const item = document.createElement('div');
                item.className = 'preview-item';

                const thumb = document.createElement('div');
                thumb.className = 'preview-thumb';

                if (file.type.startsWith('image/')) {
                    const img = document.createElement('img');
                    img.src = URL.createObjectURL(file);
                    img.onload = () => URL.revokeObjectURL(img.src);
                    thumb.appendChild(img);
                } else {
                    const icon = document.createElement('span');
                    icon.className = 'video-icon';
                    icon.textContent = '▶';
                    thumb.appendChild(icon);
                }

                const label = document.createElement('div');
                label.className = 'preview-label';
                label.textContent = file.name;
                label.title = file.name;

                item.appendChild(thumb);
                item.appendChild(label);
                previewGrid.appendChild(item);
            });
        }

        uploadBtn.addEventListener('click', () => {
            if (selectedFiles.length === 0) return;

            const formData = new FormData();
            formData.append('__RequestVerificationToken',
                document.querySelector('[name=__RequestVerificationToken]').value);
            selectedFiles.forEach(f => formData.append('files', f));

            const xhr = new XMLHttpRequest();
            xhr.open('POST', '/Admin/Media/Upload?tripId=@Model.Id');
            xhr.setRequestHeader('X-Requested-With', 'XMLHttpRequest');

            xhr.upload.addEventListener('progress', e => {
                if (!e.lengthComputable) return;
                const pct = Math.round(e.loaded / e.total * 100);
                progressBar.style.width = pct + '%';
                progressPct.textContent = pct + ' %';
            });

            xhr.addEventListener('load', () => {
                progressLabel.textContent = 'Hotovo!';
                progressBar.classList.remove('progress-bar-animated');
                progressBar.classList.add('bg-success');
                progressBar.style.width = '100%';
                progressPct.textContent = '100 %';
                setTimeout(() => window.location.reload(), 600);
            });

            xhr.addEventListener('error', () => {
                progressLabel.textContent = 'Chyba při nahrávání.';
                progressBar.classList.replace('bg-primary', 'bg-danger');
            });

            uploadBtn.disabled = true;
            uploadBtn.textContent = 'Nahrávám…';
            progressWrap.style.display = 'block';
            progressBar.style.width = '0%';

            xhr.send(formData);
        });

        // --- Sortable reorder ---
        const mediaList = document.getElementById('mediaList');
        if (mediaList) {
            Sortable.create(mediaList, {
                handle: '.drag-handle',
                animation: 150,
                ghostClass: 'sortable-ghost',
                chosenClass: 'sortable-chosen',
                onEnd: async () => {
                    const orderedIds = Array.from(mediaList.querySelectorAll('[data-id]'))
                        .map(el => parseInt(el.dataset.id));

                    const token = document.querySelector('[name=__RequestVerificationToken]').value;

                    const resp = await fetch('/Admin/Media/Reorder?tripId=@Model.Id', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': token
                        },
                        body: JSON.stringify(orderedIds)
                    });

                    const toast = document.getElementById('reorderToast');
                    if (resp.ok) {
                        toast.style.display = 'inline';
                        setTimeout(() => toast.style.display = 'none', 2000);
                    } else {
                        toast.textContent = '✗ Chyba při ukládání pořadí';
                        toast.classList.replace('text-success', 'text-danger');
                        toast.style.display = 'inline';
                        setTimeout(() => { toast.style.display = 'none'; toast.textContent = '✓ Pořadí uloženo'; toast.classList.replace('text-danger', 'text-success'); }, 3000);
                    }
                }
            });
        }
    </script>
}
