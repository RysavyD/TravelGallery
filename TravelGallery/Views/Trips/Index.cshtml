@model List<TravelGallery.ViewModels.TripTimelineItemViewModel>
@{
    ViewData["Title"] = "Výlety";
    var activeTag = ViewBag.ActiveTag as string;
    var searchQuery = ViewBag.SearchQuery as string;
    var hasFilter = !string.IsNullOrEmpty(activeTag) || !string.IsNullOrEmpty(searchQuery);
    var emptyMessage = hasFilter
        ? "Žádné výlety odpovídající vašemu hledání."
        : "Zatím žádné výlety.";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
            <h1 class="mb-0">Výlety</h1>
            @if (hasFilter)
            {
                <div class="d-flex align-items-center gap-2 flex-wrap">
                    @if (!string.IsNullOrEmpty(searchQuery))
                    {
                        <span class="badge bg-info fs-6">🔍 @searchQuery</span>
                    }
                    @if (!string.IsNullOrEmpty(activeTag))
                    {
                        <span class="badge bg-primary fs-6">@activeTag</span>
                    }
                    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">× Zrušit filtr</a>
                </div>
            }
        </div>

        @if (!Model.Any())
        {
            <div class="text-center text-muted py-5">
                <p class="fs-5">@emptyMessage</p>
            </div>
        }

        <div class="timeline">
            @foreach (var trip in Model)
            {
                <div class="card mb-4 shadow-sm trip-card">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h2 class="h5 mb-0">
                                <a asp-controller="Trips" asp-action="Detail" asp-route-id="@trip.Id"
                                   class="text-decoration-none text-dark stretched-link">
                                    @trip.Title
                                </a>
                            </h2>
                            <span class="badge bg-secondary ms-2 text-nowrap">
                                @trip.Date.ToString("d. M. yyyy")
                            </span>
                        </div>

                        @if (!string.IsNullOrEmpty(trip.ShortDescription))
                        {
                            <p class="text-muted small mb-2">@trip.ShortDescription</p>
                        }

                        @if (trip.Tags.Any())
                        {
                            <div class="d-flex flex-wrap gap-1 mb-3 position-relative" style="z-index:1;">
                                @foreach (var t in trip.Tags)
                                {
                                    var tagCss = t.Slug == activeTag ? "bg-primary" : "bg-light text-dark border";
                                    <a asp-action="Index" asp-route-tag="@t.Slug" asp-route-q="@searchQuery"
                                       class="badge text-decoration-none @tagCss">
                                        @t.Name
                                    </a>
                                }
                            </div>
                        }

                        @if (trip.ThumbnailUrls.Any())
                        {
                            <div class="d-flex gap-2 flex-wrap">
                                @foreach (var thumb in trip.ThumbnailUrls)
                                {
                                    <img src="@thumb" alt="náhled" class="trip-thumb rounded"
                                         style="width:100px;height:75px;object-fit:cover;" />
                                }
                                @if (trip.HasMoreMedia)
                                {
                                    <div class="trip-thumb-more rounded d-flex align-items-center justify-content-center bg-secondary text-white"
                                         style="width:100px;height:75px;font-size:0.85rem;">
                                        +@(trip.MediaCount - trip.ThumbnailUrls.Count) dalších
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>
