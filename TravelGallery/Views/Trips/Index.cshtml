@model List<TravelGallery.ViewModels.TripTimelineItemViewModel>
@{
    ViewData["Title"] = "Výlety";
    var activeTag = ViewBag.ActiveTag as string;
    var searchQuery = ViewBag.SearchQuery as string;
    var tripsWithCoords = Model.Where(t => t.Latitude.HasValue && t.Longitude.HasValue).ToList();
    var hasMapTrips = tripsWithCoords.Any();
    var currentPage = (int)ViewBag.CurrentPage;
    var totalPages = (int)ViewBag.TotalPages;
    var dateFrom = ViewBag.DateFrom as string;
    var dateTo = ViewBag.DateTo as string;
    var hasFilter = !string.IsNullOrEmpty(activeTag) || !string.IsNullOrEmpty(searchQuery)
                    || !string.IsNullOrEmpty(dateFrom) || !string.IsNullOrEmpty(dateTo);
    var emptyMessage = hasFilter
        ? "Žádné výlety odpovídající vašemu hledání."
        : "Zatím nejste členem žádné skupiny, nebo vaše skupina neobsahuje žádné výlety.";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
            <h1 class="mb-0">Výlety</h1>
            @if (hasFilter)
            {
                <div class="d-flex align-items-center gap-2 flex-wrap">
                    @if (!string.IsNullOrEmpty(searchQuery))
                    {
                        <span class="badge bg-info fs-6">🔍 @searchQuery</span>
                    }
                    @if (!string.IsNullOrEmpty(activeTag))
                    {
                        <span class="badge bg-primary fs-6">@activeTag</span>
                    }
                    @if (!string.IsNullOrEmpty(dateFrom) || !string.IsNullOrEmpty(dateTo))
                    {
                        <span class="badge bg-warning text-dark fs-6">
                            📅 @(dateFrom ?? "…") – @(dateTo ?? "…")
                        </span>
                    }
                    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">× Zrušit filtr</a>
                </div>
            }
        </div>

        @if (hasMapTrips)
        {
            <button class="btn btn-sm btn-outline-secondary mb-2" type="button"
                    data-bs-toggle="collapse" data-bs-target="#trips-map-collapse"
                    aria-expanded="false" aria-controls="trips-map-collapse"
                    id="map-toggle-btn">
                🗺 Zobrazit mapu výletů
            </button>
            <div class="collapse mb-3" id="trips-map-collapse">
                <div id="trips-map" style="height:340px;border-radius:10px;"></div>
            </div>
        }
        else if (Model.Any())
        {
            <p class="text-muted small mb-3">🗺 Žádný výlet na této stránce nemá zadané souřadnice.</p>
        }

        @if (!Model.Any())
        {
            <div class="text-center text-muted py-5">
                <p class="fs-5">@emptyMessage</p>
            </div>
        }

        <style>
            .visual-timeline { position: relative; padding: 20px 0; }
            .visual-timeline::before {
                content: ''; position: absolute; left: 50%; transform: translateX(-50%);
                top: 0; bottom: 0; width: 3px; background: #dee2e6;
            }
            .tl-year { position: relative; text-align: center; margin: 30px 0 20px; }
            .tl-year span {
                background: #343a40; color: #fff; padding: 6px 20px; border-radius: 20px;
                font-weight: 700; font-size: 1.1rem; position: relative; z-index: 1;
            }
            .tl-month { position: relative; text-align: center; margin: 15px 0 10px; }
            .tl-month span {
                background: #e9ecef; color: #495057; padding: 3px 14px; border-radius: 12px;
                font-size: .85rem; font-weight: 600; position: relative; z-index: 1;
            }
            .tl-item {
                position: relative; width: 45%; padding: 15px; background: var(--bs-body-bg);
                border-radius: 10px; box-shadow: 0 2px 8px rgba(0,0,0,.08); margin-bottom: 20px;
            }
            .tl-item.tl-left { margin-left: 5%; }
            .tl-item.tl-right { margin-left: 50%; }
            .tl-item::before {
                content: ''; position: absolute; top: 20px; width: 12px; height: 12px;
                background: #0d6efd; border: 3px solid #fff; border-radius: 50%;
                box-shadow: 0 0 0 2px #0d6efd; z-index: 1;
            }
            .tl-item.tl-left::before { right: -31px; }
            .tl-item.tl-right::before { left: -31px; }
            .tl-item::after {
                content: ''; position: absolute; top: 22px; width: 24px; height: 2px; background: #dee2e6;
            }
            .tl-item.tl-left::after { right: -24px; }
            .tl-item.tl-right::after { left: -24px; }
            @@media (max-width: 767px) {
                .visual-timeline::before { left: 20px; }
                .tl-item { width: calc(100% - 50px); margin-left: 50px !important; }
                .tl-item::before { left: -35px !important; right: auto !important; }
                .tl-item::after { left: -28px !important; right: auto !important; }
                .tl-year, .tl-month { text-align: left; padding-left: 50px; }
            }
        </style>

        <div class="visual-timeline">
            @{
                int? lastYear = null;
                int? lastMonth = null;
                int itemIndex = 0;
                var csCulture = new System.Globalization.CultureInfo("cs-CZ");
            }
            @foreach (var trip in Model)
            {
                var year = trip.Date.Year;
                var month = trip.Date.Month;

                if (lastYear != year)
                {
                    <div class="tl-year"><span>@year</span></div>
                    lastYear = year;
                    lastMonth = null;
                }

                if (lastMonth != month)
                {
                    <div class="tl-month"><span>@trip.Date.ToString("MMMM", csCulture)</span></div>
                    lastMonth = month;
                }

                var side = itemIndex % 2 == 0 ? "tl-left" : "tl-right";
                <div class="tl-item @side">
                    <div class="d-flex justify-content-between align-items-start mb-1">
                        <h2 class="h6 mb-0">
                            <a asp-controller="Trips" asp-action="Detail" asp-route-id="@trip.Id"
                               class="text-decoration-none text-dark">
                                @trip.Title
                            </a>
                        </h2>
                    </div>
                    <div class="text-muted" style="font-size:.8rem;">
                        @trip.Date.ToString("d. MMMM yyyy", csCulture)
                        @if (trip.MediaCount > 0)
                        {
                            <text> · 📸 @trip.MediaCount</text>
                        }
                    </div>

                    @if (!string.IsNullOrEmpty(trip.ShortDescription))
                    {
                        <p class="text-muted small mb-2 mt-1" style="line-height:1.4;">
                            @(trip.ShortDescription.Length > 120 ? trip.ShortDescription[..120] + "…" : trip.ShortDescription)
                        </p>
                    }

                    @if (trip.Tags.Any())
                    {
                        <div class="d-flex flex-wrap gap-1 mb-2">
                            @foreach (var t in trip.Tags)
                            {
                                var tagCss = t.Slug == activeTag ? "bg-primary" : "bg-light text-dark border";
                                <a asp-action="Index" asp-route-tag="@t.Slug" asp-route-q="@searchQuery"
                                   class="badge text-decoration-none @tagCss" style="font-size:.7rem;">
                                    @t.Name
                                </a>
                            }
                        </div>
                    }

                    @if (trip.ThumbnailUrls.Any())
                    {
                        <div class="d-flex gap-1 flex-wrap">
                            @foreach (var thumb in trip.ThumbnailUrls)
                            {
                                <img src="@thumb" alt="náhled" class="rounded"
                                     style="width:50px;height:38px;object-fit:cover;" loading="lazy" />
                            }
                        </div>
                    }
                </div>
                itemIndex++;
            }
        </div>

        @if (totalPages > 1)
        {
            <nav aria-label="Stránkování" class="mt-4">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                        <a class="page-link" asp-action="Index"
                           asp-route-page="@(currentPage - 1)"
                           asp-route-tag="@activeTag"
                           asp-route-q="@searchQuery"
                           asp-route-dateFrom="@dateFrom"
                           asp-route-dateTo="@dateTo">‹</a>
                    </li>
                    @for (var p = 1; p <= totalPages; p++)
                    {
                        <li class="page-item @(p == currentPage ? "active" : "")">
                            <a class="page-link" asp-action="Index"
                               asp-route-page="@p"
                               asp-route-tag="@activeTag"
                               asp-route-q="@searchQuery"
                               asp-route-dateFrom="@dateFrom"
                               asp-route-dateTo="@dateTo">@p</a>
                        </li>
                    }
                    <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                        <a class="page-link" asp-action="Index"
                           asp-route-page="@(currentPage + 1)"
                           asp-route-tag="@activeTag"
                           asp-route-q="@searchQuery"
                           asp-route-dateFrom="@dateFrom"
                           asp-route-dateTo="@dateTo">›</a>
                    </li>
                </ul>
            </nav>
        }
    </div>
</div>

@section NavFilter {
    <input type="hidden" name="tag" value="@activeTag" />
    <div class="d-flex align-items-center gap-1">
        <input type="date" name="dateFrom" value="@dateFrom"
               class="form-control form-control-sm" style="min-width:110px;max-width:130px;" title="Od" />
        <span class="text-light small">–</span>
        <input type="date" name="dateTo" value="@dateTo"
               class="form-control form-control-sm" style="min-width:110px;max-width:130px;" title="Do" />
    </div>
}

@if (hasMapTrips)
{
    @section Styles {
        <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    }

    @section Scripts {
        <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
        <script>
            const trips = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                tripsWithCoords.Select(t => new {
                    id = t.Id,
                    title = t.Title,
                    lat = t.Latitude!.Value,
                    lng = t.Longitude!.Value,
                    url = Url.Action("Detail", "Trips", new { id = t.Id })
                }),
                new System.Text.Json.JsonSerializerOptions {
                    Encoder = System.Text.Encodings.Web.JavaScriptEncoder.Default
                }
            ));

            let map = null;
            const collapseEl = document.getElementById('trips-map-collapse');
            const toggleBtn = document.getElementById('map-toggle-btn');

            collapseEl.addEventListener('show.bs.collapse', () => {
                toggleBtn.textContent = '🗺 Skrýt mapu výletů';
            });
            collapseEl.addEventListener('hide.bs.collapse', () => {
                toggleBtn.textContent = '🗺 Zobrazit mapu výletů';
            });

            collapseEl.addEventListener('shown.bs.collapse', () => {
                if (map) { map.invalidateSize(); return; }
                map = L.map('trips-map');
                L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                    attribution: '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>'
                }).addTo(map);
                const bounds = [];
                trips.forEach(t => {
                    L.marker([t.lat, t.lng]).addTo(map)
                        .bindPopup(`<strong><a href="${t.url}">${t.title}</a></strong>`);
                    bounds.push([t.lat, t.lng]);
                });
                map.fitBounds(bounds, { padding: [40, 40], maxZoom: 12 });
            });
        </script>
    }
}
