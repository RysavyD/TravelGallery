<!DOCTYPE html>
<html lang="cs">
<script>
    (function() {
        var saved = localStorage.getItem('theme');
        var theme = saved || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        document.documentElement.setAttribute('data-bs-theme', theme);
    })();
</script>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Výlety</title>
    <link rel="icon" type="image/svg+xml" href="~/favicon.svg?v=3" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/photoswipe@5/dist/photoswipe.css" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark bg-dark border-bottom mb-4">
            <div class="container">
                <a class="navbar-brand fw-bold" asp-area="" asp-controller="Trips" asp-action="Index">
                    &#9968; Výlety
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target=".navbar-collapse" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Trips" asp-action="Index">Výlety</a>
                        </li>
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="Admin" asp-controller="Trips" asp-action="Index">Admin</a>
                            </li>
                        }
                    </ul>
                    @if (ViewBag.ShowSearch == true)
                    {
                        <form asp-area="" asp-controller="Trips" asp-action="Index" method="get"
                              class="d-flex align-items-center gap-1 me-3 flex-sm-nowrap flex-wrap" role="search">
                            <div class="d-flex align-items-center gap-1">
                                <input type="search" name="q" class="form-control form-control-sm" placeholder="Hledat…"
                                       value="@ViewBag.SearchQuery" aria-label="Hledat" style="width:150px;" />
                                <button class="btn btn-outline-light btn-sm d-sm-none" type="submit">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                                        <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85zm-5.242.656a5 5 0 1 1 0-10 5 5 0 0 1 0 10z"/>
                                    </svg>
                                </button>
                            </div>
                            @await RenderSectionAsync("NavFilter", required: false)
                            <button class="btn btn-outline-light btn-sm d-none d-sm-inline-flex" type="submit">
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                                    <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85zm-5.242.656a5 5 0 1 1 0-10 5 5 0 0 1 0 10z"/>
                                </svg>
                            </button>
                        </form>
                    }
                    <ul class="navbar-nav align-items-center">
                        <li class="nav-item">
                            <button type="button" class="btn btn-link nav-link px-2" id="themeToggle"
                                    title="Přepnout tmavý/světlý režim" style="font-size:1.1rem;text-decoration:none;">
                            </button>
                        </li>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <span class="nav-link text-light">@User.Identity.Name</span>
                            </li>
                            <li class="nav-item">
                                <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-link nav-link text-warning p-0">Odhlásit</button>
                                </form>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <style>
        [data-bs-theme="dark"] body { background-color: #212529 !important; color: #dee2e6 !important; }
        [data-bs-theme="dark"] .card { background-color: #2b3035; border-color: #495057; }
        [data-bs-theme="dark"] .tl-item { background: #212529; box-shadow: 0 2px 8px rgba(0,0,0,.3); }
        [data-bs-theme="dark"] .tl-year span { background: #495057; }
        [data-bs-theme="dark"] .tl-month span { background: #343a40; color: #adb5bd; }
        [data-bs-theme="dark"] .visual-timeline::before { background: #495057; }
        [data-bs-theme="dark"] .gallery-item img { opacity: .92; }
        [data-bs-theme="dark"] .gallery-caption { color: #adb5bd !important; }
        [data-bs-theme="dark"] .drop-zone { border-color: #6c757d; }
        [data-bs-theme="dark"] .media-card { background: #212529; border-color: #495057; }
        [data-bs-theme="dark"] a.text-dark { color: #dee2e6 !important; }
        [data-bs-theme="dark"] .text-muted { color: #adb5bd !important; }
        [data-bs-theme="dark"] .badge.bg-light { background-color: #343a40 !important; color: #dee2e6 !important; }
        [data-bs-theme="dark"] h1, [data-bs-theme="dark"] h2, [data-bs-theme="dark"] h3 { color: #f8f9fa; }
    </style>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        (function() {
            var toggle = document.getElementById('themeToggle');
            function getTheme() {
                return document.documentElement.getAttribute('data-bs-theme') || 'light';
            }
            function updateIcon() {
                toggle.textContent = getTheme() === 'dark' ? '☀️' : '🌙';
            }
            updateIcon();
            toggle.addEventListener('click', function() {
                var next = getTheme() === 'dark' ? 'light' : 'dark';
                document.documentElement.setAttribute('data-bs-theme', next);
                localStorage.setItem('theme', next);
                updateIcon();
            });
            // Listen for OS theme change (only if user hasn't manually overridden)
            window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', function(e) {
                if (!localStorage.getItem('theme')) {
                    var t = e.matches ? 'dark' : 'light';
                    document.documentElement.setAttribute('data-bs-theme', t);
                    updateIcon();
                }
            });
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
